{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whichfly.example/schemas/grounding-snippets.json",
  "title": "GroundingSnippets",
  "type": "array",
  "items": { "$ref": "#/$defs/snippet" },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "use_as": {
      "type": "string",
      "enum": ["background_only"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["blog", "forum", "book", "video", "guide", "club_note", "internal_note", "other"]
        },
        "ref": { "type": "string", "minLength": 3, "maxLength": 120 }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["country", "region", "river", "river_type", "season"],
      "properties": {
        "country": { "type": "string", "enum": ["UK"] },
        "region": {
          "type": "string",
          "enum": ["south", "midlands", "north", "wales", "scotland", "ni", "unknown"]
        },
        "river": {
          "anyOf": [
            { "type": "string", "minLength": 2, "maxLength": 80 },
            { "type": "null" }
          ]
        },
        "river_type": {
          "type": "array",
          "minItems": 0,
          "maxItems": 4,
          "items": {
            "type": "string",
            "enum": ["chalkstream", "freestone", "mixed", "unknown"]
          }
        },
        "season": {
          "type": "array",
          "minItems": 0,
          "maxItems": 4,
          "items": {
            "type": "string",
            "enum": ["spring", "summer", "autumn", "winter", "unknown"]
          }
        }
      }
    },
    "snippet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "kind", "summary", "confidence", "tags", "use_as", "sources", "created_at"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_\\-]{6,80}$" },
        "scope": { "$ref": "#/$defs/scope" },
        "kind": {
          "type": "string",
          "enum": ["angler_reports", "general_guidance", "river_type_guidance", "safety_note"]
        },
        "summary": { "type": "string", "minLength": 30, "maxLength": 280 },
        "confidence": { "$ref": "#/$defs/confidence" },
        "tags": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": { "type": "string", "minLength": 2, "maxLength": 40 }
        },
        "use_as": { "$ref": "#/$defs/use_as" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/source" }
        },
        "created_at": { "type": "string", "format": "date" }
      }
    }
  }
}
