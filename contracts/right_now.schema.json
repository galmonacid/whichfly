{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whichfly.example/schemas/right-now-response.json",
  "title": "RightNowResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["river", "primary", "alternatives", "explanation", "confidence", "confidence_reasons", "meta"],
  "properties": {
    "river": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "confidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "source": { "type": "string", "enum": ["gps_suggested", "user_selected", "unknown"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "distance_m": { "type": "number", "minimum": 0, "maximum": 20000 }
      }
    },
    "primary": {
      "$ref": "#/$defs/fly_pick"
    },
    "alternatives": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/conditional_fly_pick"
      }
    },
    "explanation": {
      "type": "string",
      "minLength": 20,
      "maxLength": 360
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "confidence_reasons": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 3, "maxLength": 120 }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "mode"],
      "properties": {
        "version": { "type": "string", "minLength": 1, "maxLength": 20 },
        "mode": { "type": "string", "enum": ["right_now", "planning"] },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "$defs": {
    "fly_type": {
      "type": "string",
      "enum": ["dry", "nymph", "streamer", "wet", "emerger"]
    },
    "fly_pick": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "type", "size"],
      "properties": {
        "pattern": { "type": "string", "minLength": 2, "maxLength": 60 },
        "type": { "$ref": "#/$defs/fly_type" },
        "size": {
          "type": "integer",
          "minimum": 6,
          "maximum": 24
        }
      }
    },
    "conditional_fly_pick": {
      "allOf": [
        { "$ref": "#/$defs/fly_pick" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["when"],
          "properties": {
            "when": {
              "type": "string",
              "minLength": 10,
              "maxLength": 120
            }
          }
        }
      ]
    }
  }
}
