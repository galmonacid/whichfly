{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whichfly.example/schemas/by-the-riverside-response.json",
  "title": "ByTheRiversideResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["river", "primary", "alternatives", "explanation", "confidence", "confidence_reasons", "context_used", "meta"],
  "properties": {
    "river": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "confidence", "distance_m"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "source": { "type": "string", "enum": ["gps_suggested", "user_selected", "unknown"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "distance_m": { "type": ["number", "null"], "minimum": 0, "maximum": 20000 }
      }
    },
    "primary": {
      "$ref": "#/$defs/fly_pick"
    },
    "alternatives": {
      "type": "array",
      "minItems": 0,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/conditional_fly_pick"
      }
    },
    "explanation": {
      "type": "string",
      "minLength": 20,
      "maxLength": 360
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "confidence_reasons": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 3, "maxLength": 120 }
    },
    "context_used": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weather", "daylight"],
      "properties": {
        "weather": {
          "type": "object",
          "additionalProperties": false,
          "required": ["temperature_c", "precipitation_mm", "cloud_cover_pct", "wind_speed_kph"],
          "properties": {
            "temperature_c": { "type": ["number", "null"] },
            "precipitation_mm": { "type": ["number", "null"] },
            "cloud_cover_pct": { "type": ["number", "null"] },
            "wind_speed_kph": { "type": ["number", "null"] }
          }
        },
        "daylight": {
          "type": "object",
          "additionalProperties": false,
          "required": ["is_daylight", "minutes_to_sunset"],
          "properties": {
            "is_daylight": { "type": ["boolean", "null"] },
            "minutes_to_sunset": { "type": ["number", "null"] }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "mode", "generated_at"],
      "properties": {
        "version": { "type": "string", "minLength": 1, "maxLength": 20 },
        "mode": { "type": "string", "enum": ["by_the_riverside", "planning"] },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "$defs": {
    "fly_type": {
      "type": "string",
      "enum": ["dry", "nymph", "streamer", "wet", "emerger"]
    },
    "fly_pick": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "type", "size"],
      "properties": {
        "pattern": { "type": "string", "minLength": 2, "maxLength": 60 },
        "type": { "$ref": "#/$defs/fly_type" },
        "size": {
          "type": "integer",
          "minimum": 6,
          "maximum": 24
        }
      }
    },
    "conditional_fly_pick": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "type", "size", "when"],
      "properties": {
        "pattern": { "type": "string", "minLength": 2, "maxLength": 60 },
        "type": { "$ref": "#/$defs/fly_type" },
        "size": {
          "type": "integer",
          "minimum": 6,
          "maximum": 24
        },
        "when": {
          "type": "string",
          "minLength": 10,
          "maxLength": 120
        }
      }
    }
  }
}
